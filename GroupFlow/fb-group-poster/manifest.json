{
  "manifest_version": 3,
  "name": "GroupFlow — FB Group Auto Poster",
  "version": "1.0.187",
  "incognito": "not_allowed",
  "description": "Đăng bài FB Group, AI local, comment chéo, Radar — tuỳ chọn sync tidien.xyz",
  "permissions": [
    "storage",
    "alarms",
    "downloads",
    "tabs",
    "activeTab",
    "scripting",
    "notifications",
    "cookies"
  ],
  "host_permissions": [
    "https://www.facebook.com/*",
    "https://facebook.com/*",
    "https://m.facebook.com/*",
    "https://upload.facebook.com/*",
    "https://tidien.xyz/*",
    "http://localhost:3001/*",
    "http://localhost/*",
    "https://www.googleapis.com/*",
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.ideogram.ai/*",
    "https://*.ideogram.ai/*",
    "https://openrouter.ai/*",
    "https://*.blob.core.windows.net/*"
  ],
  "optional_host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "GroupFlow — mở panel",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.facebook.com/*",
        "https://facebook.com/*",
        "https://m.facebook.com/*",
        "https://tidien.xyz/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": ["modules/gfPanelShell.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.facebook.com/*",
        "https://facebook.com/*",
        "https://m.facebook.com/*"
      ],
      "js": [
        "modules/gfShared.js",
        "selectors.js",
        "modules/groupParse.js",
        "modules/fbGraphApi.js",
        "modules/fbActor.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "sidepanel.html",
        "sidepanel.css",
        "sidepanel.js",
        "lib/*",
        "modules/*",
        "icons/*",
        "selectors.js"
      ],
      "matches": ["<all_urls>"]
    },
    {
      "resources": ["modules/pageNetworkHook.js"],
      "matches": [
        "https://www.facebook.com/*",
        "https://facebook.com/*",
        "https://m.facebook.com/*"
      ]
    }
  ]
}
