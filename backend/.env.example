NODE_ENV=development
PORT=3001
DB_HOST=localhost
DB_PORT=3306
DB_NAME=autopost_db
DB_USER=autopost_user
DB_PASS=your_strong_password
JWT_SECRET=your_jwt_secret_minimum_32_characters
JWT_EXPIRES_IN=7d
CLAUDE_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
IDEOGRAM_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
MAX_IMAGES_MB=5000
MAX_VIDEOS_MB=5000
IMAGE_CLEANUP_DAYS=30
VIDEO_CLEANUP_DAYS=7
STORAGE_WARNING_PERCENT=80
MAX_VIDEO_UPLOAD_MB=500
PUBLIC_BASE_URL=http://localhost:3001
FB_GRAPH_API=https://graph.facebook.com/v19.0
DISABLE_SCHEDULER=false

# Lưu ảnh: local (VPS) hoặc google_drive
# MEDIA_STORAGE=google_drive
# Google Drive dùng OAuth2 User Authentication — cấu hình trên UI: Cài đặt → Google Drive
# (Client ID, Client Secret, Refresh Token, Folder ID lưu trong app_settings, không dùng .env)
# Ảnh AI/upload sẽ lưu Drive; VPS chỉ stream tạm khi đăng FB

# Composio — chỉ cấu hình trên UI: Cài đặt → Composio (lưu database app_settings, không dùng .env)

